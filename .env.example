# ===== Backend (apps/api) =====
PORT=3300
LOG_LEVEL=info

# Mongo & Redis
MONGO_URI=mongodb://localhost:27017/sred
REDIS_URL=redis://localhost:6379

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY=

# Airtable OAuth (PKCE)
AIRTABLE_OAUTH_CLIENT_ID=
AIRTABLE_OAUTH_CLIENT_SECRET=
AIRTABLE_OAUTH_REDIRECT_URI=http://localhost:3300/api/airtable/oauth/callback

# Airtable scraper
AIRTABLE_SCRAPER_HEADLESS=true
AIRTABLE_SCRAPER_PROFILE_DIR=./.playwright-profiles

WEB_ORIGIN=http://localhost:4200
WEB_API_BASE=http://localhost:3300
WEB_SOCKET_URL=http://localhost:3300

SEED_AIRTABLE_PAT=
SEED_AIRTABLE_BASE_ID=
